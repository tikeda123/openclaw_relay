# Copy to /etc/default/openclaw-relay and adjust values for the target host.
#
# Core gateway credentials
# If you use remote token fetch through SSH tunnels, leave these unset.
# A_GATEWAY_TOKEN=
# B_GATEWAY_TOKEN=
#
# RabbitMQ transport credentials
RABBITMQ_USER=relay
RABBITMQ_PASSWORD=relay-dev-pass

# Mailbox API bearer tokens
# Relay derives the sender mailbox from these tokens.
# RELAY_MAILBOX_TOKEN_OPTIONABC001=
# RELAY_MAILBOX_TOKEN_OPTIONDEF002=
